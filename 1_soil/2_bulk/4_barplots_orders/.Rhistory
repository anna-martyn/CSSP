##Load required package.
library(multcompView)
## Specify orders for which significance testing is to be performed (here top20).
order_levels <- c("Acidobacteriales", "Burkholderiales", "Chloroflexales", "Corynebacteriales", "Frankiales", "Gaiellales", "Gemmatimonadales", "MB-A2-108", "Micrococcales", "Nitrospirales", "Pedosphaerales", "Propionibacteriales", "Pseudomonadales", "Rhizobiales", "S085", "Solibacterales", "Sphingomonadales", "Subgroup_7", "TK10", "Xanthomonadales", "Other")
#Perform ANOVA and make .csv file with resulting p-values.
for (order_name in order_levels) {
idx <- df.long_order_bulk$Order %in% order_name
df_order <- df.long_order_bulk[idx,] # Create subset dataframe for specific order.
ano <- aov(RA ~ Soil, data = df_order) # Perform an ANOVA test.
print(anova(ano)) # Print the ANOVA results.
p_values <- summary(ano)[["Pr(>F)"]]["Soil", "Pr(>F)"]
cat("P-value for Soil in order", order_name, "is", p_values, "\n")
filename <- paste("Barley_CSSP_bysoils_", gsub("/", "", order_name), "_pvalue.csv", sep = "")
result_df <- p_values # Extract the p-values.
write.csv(result_df, file = filename) # Write .csv file.
}
for (order_name in order_levels) {
idx <- df.long_order_bulk$Order %in% order_name
df_order <- df.long_order_bulk[idx,] # Create subset dataframe for specific order.
ano <- aov(RA ~ Soil, data = df_order) # Perform an ANOVA test.
anova(ano) # Print the ANOVA results.
pairwise <- TukeyHSD(ano) # Perform a Tukey's HSD test.
generate_label_df <- function(pairwise, variable){
Tukey.levels <- pairwise[[variable]][,4]
Tukey.labels <- data.frame(multcompLetters(Tukey.levels)['Letters'])
return(Tukey.labels) # Generate significance labels.
}
LABELS=generate_label_df(pairwise , "Soil")
filename <- paste("Barley_CSSP_bysoils_", gsub("/", "", order_name), "_ANOVA.csv", sep = "") # Save labels to a .csv file.
write.csv(LABELS, file = filename)
}
## Now print a list and create vector only showing orders with significant differences
# Initialize a vector to store significant orders
significant_orders <- c()
# Clean up.
options(warn=-1)
rm(list=ls())
# Set working directory.
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
# Load data.
design.file <- paste("BarleyCSSP_Askov_reseq_metadata.txt", sep="")
taxonomy.file <- paste("Barley_Askov_Rep_10_4_taxonomy.txt", sep="")
asv_table.file <- paste("BarleyCSSP_Askov_reseq_ASVtable_10_4.txt", sep="")
design <- read.table(design.file, header=T, sep="\t")
asv_table <- read.table(asv_table.file, sep="\t", header=T, row.names=1, check.names=F)
taxonomy <- read.table(taxonomy.file, sep="\t", header=T, fill=T)
# Load required packages.
library(data.table)
library(stringr)
library(dplyr)
library(ggplot2)
library(reshape2)
library(RColorBrewer)
library(ggh4x)
library(multcompView)
# Clean-up taxonomy file layout.
taxa <- lapply(as.list(taxonomy$Taxon),
function(x) x %>% strsplit(split = "; ") %>% unlist() %>% substr(start = 4, stop = 100))
taxa <- lapply(taxa, function(x) c( x, rep("Unknown", 7 - length(x)) ))
taxa <- lapply(taxa, function(x)
data.table(Kingdom = x[1],
Phylum = x[2],
Class = x[3],
Order = x[4],
Family = x[5],
Genus = x[6],
Species = x[7])
)
taxa <- rbindlist(taxa)
taxonomy <- data.table(ASV = taxonomy$`ASVid`, taxa, Confidence = taxonomy$Confidence)
# Remove the three Lotus soil samples from the dataset.
design <- design[1:188, ]
# Re-order data matrices.
idx <- design$Sample_ID %in% colnames(asv_table)
design <- design[idx, ]
idx <- match(design$Sample_ID, colnames(asv_table))
asv_table <- asv_table[, idx]
idx <- rownames(asv_table) %in% taxonomy$ASV
asv_table <- asv_table[idx, ]
idx <- match(design$Sample_ID, colnames(asv_table))
asv_table <- asv_table[, idx]
# Convert ASV reads to relative abundances and save as new dataframe.
asv_table_norm <- apply(asv_table, 2, function(x) x / sum(x))
df <- as.data.frame(asv_table_norm)
# Add taxonomy information (here bacterial order) to dataframe.
tax_order <- taxonomy[ ,5]
df$Order <- tax_order
ASVid <- row.names(df)
df <- cbind(ASVid, df)
row.names(df) <- NULL
# Reshape data to long dataframe.
df.long <- reshape(df, varying = 2:189, direction = "long", idvar = 'ASVid', timevar="sampleID", v.names=c("RA"),
times=c(colnames(df[,2:189])), sep="")
row.names(df.long) <- NULL
df.long <- as.data.frame(df.long)
# Filter data to only keep info that is needed, and calculate total relative abundance of each bacterial order for each sample.
df.long_order <- df.long %>% select (2:4)
df.long_order <- df.long_order %>%
group_by_(.dots = c("Order", "sampleID")) %>%
summarise_all(funs(sum))
# Add genotype information to each sample.
df2 <- data.frame(sampleID = design$Sample_ID, Soil=design$Soil, Genotype=design$Genotype)
df.long_order <- full_join(df.long_order, df2, by="sampleID")
# Subset to only keep soil samples.
idx <- df.long_order$Genotype%in% c("Soil")
df.long_order_bulk <- df.long_order[idx,]
# Calculate mean relative abundance for each order across all samples.
mean_RA_order_bulk <- df.long_order_bulk %>%
group_by(Order) %>%
dplyr::summarize(Mean = mean(RA, na.rm = TRUE))
mean_RA_order_bulk <- as.data.frame(mean_RA_order_bulk)
mean_RA_order_bulk <- mean_RA_order_bulk[order(-mean_RA_order_bulk$Mean),]
# Check how many unique orders given.
unique(df.long_order_bulk$Order)
# Show top 20 orders with highest mean relative abundance.
mean_RA_order_bulk %>% top_n(20)
# Alternatively check for orders with mean relatove abundance >1% (not used for display here).
above1per <- mean_RA_order_bulk[mean_RA_order_bulk$Mean >= 0.01, ]
unique(above1per$Order)
# Keep orders belonging to top20 and combine rest as "Other".
do_not_replace_bulk <- c("Acidobacteriales","Burkholderiales","Chloroflexales","Corynebacteriales","Frankiales","Gaiellales","Gemmatimonadales","MB-A2-108","Micrococcales","Nitrospirales","Pedosphaerales","Propionibacteriales","Pseudomonadales","Rhizobiales","S085","Solibacterales","Sphingomonadales","Subgroup_7","TK10","Xanthomonadales")
df.long_order_bulk$Order <- ifelse(df.long_order_bulk$Order$Order%in%do_not_replace_bulk, df.long_order_bulk$Order$Order, "Other")
# Check whether it worked.
unique(df.long_order_bulk$Order)
# Calculate standard deviation and standard error for plots.
df.long_order_bulk_summary <- df.long_order_bulk %>%
group_by(Order, Soil) %>%
summarise(
Mean_RA = mean(RA, na.rm = TRUE),
SD_RA = sd(RA, na.rm = TRUE),
SE_RA = SD_RA / sqrt(n())
)
# Define colours for plot.
colors2 <- data.frame(group=c("NPK", "PK","UF"),
color=c("#6D3B00","#A06A37","#D2B48C"))
# Make plot.
dodge <- position_dodge(width = 0.9)
main_theme <- theme(panel.background=element_blank(),
panel.grid.major = element_line(color = "gray90"),
panel.grid=element_blank(),
panel.border = element_rect(colour = "black", fill=NA, linewidth=1),
axis.line.x=element_line(color="black"),
axis.line.y=element_line(color="black"),
axis.ticks=element_line(color="black"),
axis.text = element_text(size = 20, color = "black"),
legend.text = element_text(size=20, color = "black"),
legend.key=element_blank(),
axis.title.y = element_text(size = 20),
legend.position=c(0.915,0.8),
legend.background = element_rect(colour = "black", fill = NA),
text=element_text(family="sans",size=20, color="black"))
p1 <- ggplot(df.long_order_bulk_summary, aes(x = Order, y = Mean_RA, fill = Soil)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.9), width = 0.8) +
geom_errorbar(aes(ymin = Mean_RA - SE_RA, ymax = Mean_RA + SE_RA),
width = 0.3, position = position_dodge(width = 0.9), color = "black") +
geom_point(aes(group = Soil), position = position_dodge(width = 0.9), size = 1, alpha = 0.5, show.legend = FALSE) +
scale_fill_manual(values = as.character(colors2$color)) +
labs(x = "", y = "Relative Abundance") +
scale_y_continuous(limits = c(0, 0.15)) +
main_theme +
theme(axis.title.x = element_blank(),
axis.text.x = element_text(size = 20, angle = 50, hjust = 1))
p1
ggsave(paste("Barley_barplot_bulk_top20_RA_new.png", sep=""), p1, width=16, height=12)
ggsave(paste("Barley_barplot_bulk_top20_RA_new.pdf", sep=""), p1, width=16, height=12)
# Significance analysis
## Specify orders for which significance testing is to be performed (here top20).
order_levels <- c("Acidobacteriales", "Burkholderiales", "Chloroflexales", "Corynebacteriales", "Frankiales", "Gaiellales", "Gemmatimonadales", "MB-A2-108", "Micrococcales", "Nitrospirales", "Pedosphaerales", "Propionibacteriales", "Pseudomonadales", "Rhizobiales", "S085", "Solibacterales", "Sphingomonadales", "Subgroup_7", "TK10", "Xanthomonadales", "Other")
## Perform ANOVA and make .csv file with resulting p-values.
for (order_name in order_levels) {
idx <- df.long_order_bulk$Order %in% order_name
df_order <- df.long_order_bulk[idx,] # Create subset dataframe for specific order.
ano <- aov(RA ~ Soil, data = df_order) # Perform an ANOVA test.
print(anova(ano)) # Print the ANOVA results.
p_values <- summary(ano)[["Pr(>F)"]]["Soil", "Pr(>F)"]
cat("P-value for Soil in order", order_name, "is", p_values, "\n")
filename <- paste("Barley_CSSP_bysoils_", gsub("/", "", order_name), "_pvalue.csv", sep = "")
result_df <- p_values # Extract the p-values.
write.csv(result_df, file = filename)
}
for (order_name in order_levels) {
idx <- df.long_order_bulk$Order %in% order_name
df_order <- df.long_order_bulk[idx,] # Create subset dataframe for specific order.
ano <- aov(RA ~ Soil, data = df_order) # Perform an ANOVA test.
anova(ano) # Print the ANOVA results.
pairwise <- TukeyHSD(ano) # Perform a Tukey's HSD test.
generate_label_df <- function(pairwise, variable){
Tukey.levels <- pairwise[[variable]][,4]
Tukey.labels <- data.frame(multcompLetters(Tukey.levels)['Letters'])
return(Tukey.labels) # Generate significance labels.
}
LABELS=generate_label_df(pairwise , "Soil")
filename <- paste("Barley_CSSP_bysoils_", gsub("/", "", order_name), "_ANOVA.csv", sep = "") # Save labels to a .csv file.
write.csv(LABELS, file = filename)
}
# Now print a list and create vector only showing orders with significant differences.
## Initialize a vector to store significant orders.
significant_orders <- c()
## Loop over each order.
for (order_name in order_levels) {
idx <- df.long_order_bulk$Order %in% order_name # Subset the dataframe for the current order.
df_order <- df.long_order_bulk[idx,]
ano <- aov(RA ~ Soil, data = df_order) # Perform ANOVA.
pairwise <- TukeyHSD(ano) # Perform Tukey's HSD test.
LABELS <- generate_label_df(pairwise, "Soil") # Generate labels for significant differences.
if (!all(LABELS$Letters == "a")) { # Check if any labels are not "a"
significant_orders <- c(significant_orders, order_name)
}
}
# Print the vector of significant orders.
cat("Significant Orders:", paste(significant_orders, collapse = ", "), "\n")
# Make a graph only showing orders with significant differences across soil types.
idx <- df.long_order_bulk$Order%in% significant_orders
df.long_order_bulk_sign <- df.long_order_bulk[idx,]
# Calculate mean relative abundance, standard deviation, and standard error for plot.
df.long_order_bulk_sign_summary <- df.long_order_bulk_sign %>%
group_by(Order, Soil) %>%
summarise(
Mean_RA = mean(RA, na.rm = TRUE),
SD_RA = sd(RA, na.rm = TRUE),
SE_RA = SD_RA / sqrt(n())  # Standard Error
)
# Set colours for plot.
colors2 <- data.frame(group=c("NPK", "PK","UF"),
color=c("#6D3B00","#A06A37","#D2B48C"))
# Make the plot.
dodge <- position_dodge (width = 0.9)
main_theme <- theme(panel.background=element_blank(),
#panel.grid=element_blank(),
panel.grid.major = element_line(color = "gray90"),
panel.border = element_rect(colour = "black", fill=NA, linewidth=1),
axis.line.x=element_line(color="black"),
axis.line.y=element_line(color="black"),
axis.ticks=element_line(color="black"),
axis.text = element_text(size = 20, color = "black"),
legend.text = element_text(size=20, color = "black"),
legend.key=element_blank(),
axis.title.y = element_text(size = 20),
legend.position=c(0.925,0.85),
legend.background = element_rect(colour = "black", fill = NA),
text=element_text(family="sans",size=20, color="black"))
p2 <- ggplot(df.long_order_bulk_sign_summary, aes(x = Order, y = Mean_RA, fill = Soil)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.9), width = 0.8) +
geom_errorbar(aes(ymin = Mean_RA - SE_RA, ymax = Mean_RA + SE_RA),
width = 0.3, position = position_dodge(width = 0.9), color = "black") +
geom_point(aes(group = Soil), position = position_dodge(width = 0.9), size = 1, alpha = 0.5) +
scale_fill_manual(values = as.character(colors2$color)) +
labs(x = "", y = "Relative Abundance") +
scale_y_continuous(limits = c(0, 0.15)) +
main_theme +
theme(axis.title.x = element_blank(),
axis.text.x = element_text(size = 20, angle = 40, hjust = 1))
p2
# Save the updated plot
ggsave(paste("Barley_barplot_bulk_top20_RA_sign_new.png", sep=""), p2, width=10, height=8)
ggsave(paste("Barley_barplot_bulk_top20_RA_sign_new.pdf", sep=""), p2, width=10, height=8)
