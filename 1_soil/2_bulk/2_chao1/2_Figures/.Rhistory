# load data
design <- read.table(design.file, header=T, sep="\t")
alpha <- read.table(alpha.file, sep="\t", header=T, check.names=F, row.names = 1)
View(alpha)
# Combine alpha diversity (chao1) info and metadata info.
index <- cbind(alpha[,1], design[match(row.names(alpha), design$Sample_ID), ])
colnames(index)[1] <- "value"
View(index)
# Filter to only keep soil data.
idx <- index$Genotype %in% c( "Soil")
index_bulk <- index[idx, ]
View(index_bulk)
# Remove three Lotus soil samples and only keep barley ones.
index_bulk <- index_bulk[-c(7:9), ]
# Load package for plotting.
library(ggplot2)
# Define colours and groups for plot.
colors <- data.frame(group=c("NPK","PK","UF"), color=c("#1b9e77","#d95f02","#666666"))
?complete.cases
View(index_bulk)
l1 <- c("NPK", "PK", "UF")
index_bulk$Soil <- factor(index_bulk$Soil, levels=l1)
colors <- colors[match(l1, colors$group), ]
# Make plot.
