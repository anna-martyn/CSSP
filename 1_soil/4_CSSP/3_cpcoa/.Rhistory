y=paste("CPCo 2 (", format(100 * eig[2] / sum(eig), digits=4), "%)", sep="")) +
ggtitle(paste(format(100 * variance, digits=3), " % of variance; p=",
format(p.val, digits=2),
sep="")) +
main_theme +
theme(legend.position="right",
plot.title = element_text(size = 30, face="bold"),
legend.title = element_text(size = 30),
legend.text = element_text(size = 30),
axis.title.x = element_text(size = 30),
axis.title.y = element_text(size = 30))
p5
ggsave(paste("cpcoa_Genotype_PK_Barley_root_NEW.png", sep=""), p5, width=10, height=8)
ggsave(paste("cpcoa_Genotype_PK_Barley_root_NEW.pdf", sep=""), p5, width=10, height=8)
### root UF
otu_table_norm <- apply(otu_table_root_UF, 2, function(x) x / sum(x))
bray_curtis <- vegdist(t(otu_table_norm), method="bray")
colors <- data.frame(group=c("WT", "symrk","ccamk","nsp1", "nsp2"),
color=c("#A9C289","#FEDA8B","#FDB366","#C0E4EF","#6EA6CD"))
colors <- colors[colors$group %in% design_root_UF$Genotype, ]
sqrt_transform <- T
capscale.gen <- capscale(t(otu_table_norm) ~ Genotype + Condition(Bio_rep), data=design_root_UF, add=F, sqrt.dist=sqrt_transform, distance="bray")
# ANOVA-like permutation analysis
perm_anova.gen <- anova.cca(capscale.gen)
print(perm_anova.gen)
# generate variability tables and calculate confidence intervals for the variance
var_tbl.gen <- variability_table(capscale.gen)
eig <- capscale.gen$CCA$eig
variance <- var_tbl.gen["constrained", "proportion"]
p.val <- perm_anova.gen[1, 4]
# extract the weighted average (sample) scores
points <- capscale.gen$CCA$wa[, 1:2]
points <- as.data.frame(points)
colnames(points) <- c("x", "y")
points <- cbind(points, design_root_UF[match(rownames(points), design_root_UF$Sample_ID), ])
points$Genotype <- factor(points$Genotype, levels=colors$group)
# plot CPCo 1 and 2
p6 <- ggplot(points, aes(x=x, y=y, color=Genotype)) +
stat_ellipse(type = "norm", level = 0.8)+
geom_point(size=8) +
scale_colour_manual(values=as.character(colors$color)) +
labs(x=paste("CPCo 1 (", format(100 * eig[1] / sum(eig), digits=4), "%)", sep=""),
y=paste("CPCo 2 (", format(100 * eig[2] / sum(eig), digits=4), "%)", sep="")) +
ggtitle(paste(format(100 * variance, digits=3), " % of variance; p=",
format(p.val, digits=2),
sep="")) +
main_theme +
theme(legend.position="right",
plot.title = element_text(size = 30, face="bold"),
legend.title = element_text(size = 30),
legend.text = element_text(size = 30),
axis.title.x = element_text(size = 30),
axis.title.y = element_text(size = 30))
p6
ggsave(paste("cpcoa_Genotype_UF_Barley_root_NEW.png", sep=""), p6, width=10, height=8)
ggsave(paste("cpcoa_Genotype_UF_Barley_root_NEW.pdf", sep=""), p6, width=10, height=8)
