scale_fill_manual(values = colors) +
labs(x = "", y = "Relative Abundance of Rhizobiales") +
# ggtitle("Rhizobiales - Rhizosphere") +
main_theme
# Save plot
ggsave("Rhizobiales_Rhizosphere_CSSP.png", p, width = 5, height = 6)
ggsave("Rhizobiales_Rhizosphere_CSSP.pdf", p, width = 5, height = 6)
# Display plot
print(p)
options(warn=-1)
# Cleanup
rm(list=ls())
# Libraries
library(ggplot2)
library(reshape2)
library(RColorBrewer)
library(ggh4x)
library(dplyr)
library(tibble)
# Set working directory
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
# Files
design.file <- "BarleyCSSP_SConly_metadata_NEW.txt"
taxonomy.file <- "CerealSC_taxonomy_new_May23.txt"
otu_table.file <- "BarleyCSSP_SConly_ASVtable.txt"
# Load data
design <- read.table(design.file, header=TRUE, sep="\t")
otu_table <- read.table(otu_table.file, header=TRUE, sep="\t", row.names=1, check.names=FALSE)
taxonomy <- read.table(taxonomy.file, header=TRUE, sep="\t", fill=TRUE)
# Align samples
idx <- design$SampleID %in% colnames(otu_table)
design <- design[idx, ]
idx <- match(design$SampleID, colnames(otu_table))
otu_table <- otu_table[, idx]
idx <- rownames(otu_table) %in% taxonomy$ASVid
otu_table <- otu_table[idx, ]
idx <- match(rownames(otu_table), taxonomy$ASVid)
taxonomy <- taxonomy[idx, ]
# Normalize OTU table
otu_table_norm <- apply(otu_table, 2, function(x) x / sum(x))
otu_table_norm <- as.data.frame(otu_table_norm)
otu_table_norm <- rownames_to_column(otu_table_norm, var = "ASVid")
# Merge with taxonomy
merged <- merge(otu_table_norm, taxonomy, by = "ASVid")
# Reshape to long format
long_df <- reshape2::melt(
merged,
id.vars = colnames(taxonomy),
variable.name = "SampleID",
value.name = "RA"
)
# Add design info
long_df <- left_join(long_df, design[, c("SampleID", "Genotype", "Compartment")], by = "SampleID")
# Filter: Rhizobiales in rhizosphere for selected genotypes
filtered_df <- long_df %>%
filter(Order == "Rhizobiales",
Compartment == "rhizo",
Genotype %in% c("WT", "symrk", "ccamk", "nsp1", "nsp2"))
# Summarize cumulative relative abundance per sample
summed_df <- filtered_df %>%
group_by(SampleID, Genotype) %>%
summarise(Total_RA = sum(RA), .groups = "drop")
# Set Genotype order
summed_df$Genotype <- factor(summed_df$Genotype, levels = c("WT", "symrk", "ccamk", "nsp1", "nsp2"))
# Define colors (from your script)
colors <- c("WT" = "#A9C289",
"symrk" = "#FEDA8B",
"ccamk" = "#FDB366",
"nsp1" = "#C0E4EF",
"nsp2" = "#6EA6CD")
# Define plot theme
main_theme <- theme(panel.background=element_blank(),
panel.grid=element_blank(),
panel.border = element_rect(colour = "black", fill=NA, size=1),
axis.line=element_line(color="black"),
axis.ticks=element_line(color="black"),
axis.text=element_text(colour="black", size=20),
legend.position="none",
legend.background=element_blank(),
legend.key=element_blank(),
text=element_text(family="sans"),
plot.title = element_text(size = 20),
strip.text.x = element_text(size = 20),
axis.title.x = element_blank(),
axis.title.y = element_text(size = 20),
axis.text.x = element_text(size = 20, angle = 70, hjust = 1))
# Plot
p <- ggplot(summed_df, aes(x = Genotype, y = Total_RA, fill = Genotype)) +
geom_boxplot(width = 0.5, outlier.color = NA) +
geom_jitter(position = position_jitter(width = 0.2), size = 3, alpha = 0.5) +
scale_fill_manual(values = colors) +
labs(x = "", y = "Relative Abundance of Rhizobiales") +
# ggtitle("Rhizobiales - Rhizosphere") +
main_theme
# Save plot
ggsave("Rhizobiales_Rhizosphere_CSSP.png", p, width = 4, height = 6)
ggsave("Rhizobiales_Rhizosphere_CSSP.pdf", p, width = 4, height = 6)
# Display plot
print(p)
options(warn=-1)
# Cleanup
rm(list=ls())
