geom_tile() +
scale_fill_gradient(low = "white", high = "blue") + # Adjust colors as needed
facet_grid(Compartment ~ Soil) + # Faceting by Compartment and Soil
labs(x = "Genotype", y = "Order", fill = "RA") +
theme_minimal() +
