# cleanup
rm(list=ls())
# directory
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
# files
weight.file <- paste("Input_OX&SYM_mutant_harvest_2.txt", sep = "")
# load data
weight <- read.table(weight.file, header=T, sep="\t")
weight <- as.data.frame(weight)
weight$Fresh_weight <- gsub("\\,",".",weight$Fresh_weight)
weight$Fresh_weight <- as.numeric(weight$Fresh_weight)
# set color for the genotype
# colors <- data.frame(group=c("NPK", "PK","UF"),
#                      color=c("#1b9e77","#d95f02","#666666")) ### color used here is from "Dark2"
colors <- data.frame(group=c("NPK","PK","UF"), color=c("#6D3B00","#A06A37","#D2B48C"))
# set order for plants
weight$Soil_type <- factor(weight$Soil_type, levels = colors$group)
weight$Experiment <- factor(weight$Experiment, levels = c("Lotus_CSSP","Barley_CSSP","Barley_OX"))
idx <- weight$Genotype%in% c("WT")
WT_weight <- weight[idx,]
idx <- WT_weight$Plant_species%in% c("Barley")
WT_Barley <- WT_weight[idx,]
idx <- WT_Barley$Experiment%in% c("Barley_CSSP")
WT_Barley_CSSP <- WT_Barley[idx,]
idx <- WT_Barley$Experiment%in% c("Barley_OX")
WT_Barley_OX <- WT_Barley[idx,]
