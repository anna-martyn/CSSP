axis.line.y=element_line(color="black"),
axis.ticks=element_line(color="black"),
axis.text.x = element_text(size = 20, angle = 45, vjust = 1, hjust=1),
axis.text.y = element_text(size = 20),
#legend.position="top",
legend.background=element_blank(),
legend.key=element_blank(),
text=element_text(family="sans"))
## boxplot
dodge <- position_dodge(width = 0.9)
idx <- WT_weight$Plant%in% c("Barley")
Barley_WT_weight <- WT_weight[idx,]
idx <- WT_weight$Plant%in% c("Lotus")
Lotus_WT_weight <- WT_weight[idx,]
p3 <- ggplot(Lotus_WT_weight, aes(x=Soil_type, y=Fresh_weight, fill=Soil_type)) +
geom_boxplot(aes(shape=Soil_type), width=0.3,position = dodge,outlier.color = NA, alpha=0.7)+
geom_jitter(position=position_jitterdodge(jitter.width = 0), size=3, alpha=0.3)+
# geom_jitter(position=position_jitterdodge(jitter.width = 0.3), size=3, alpha=0.3)+
scale_fill_manual(values=as.character(colors$color)) +
main_theme +
ylab("Shoot fresh weight/plant (g)")+
scale_y_continuous()+
ggtitle("Lotus")+
theme(legend.position="none",
plot.title = element_text(size = 20, face="bold"),
legend.title = element_text(size = 20),
strip.text.x = element_text(size = 20),
legend.text = element_text(size = 20),
axis.title.x = element_blank(),
axis.title.y = element_text(size = 20),
axis.text.y = element_text(size = 20, colour = "black"),
axis.text.x = element_text(size = 20, colour = "black"),
legend.key.size = unit(1,"cm"))
p3
ggsave(paste("Lotus_WT_per_soiltype_fw_BOX.png", sep=""), p3, width=3.5, height=6)
ggsave(paste("Lotus_WT_per_soiltype_fw_BOX.pdf", sep=""), p3, width=3.5, height=6)
p4 <- ggplot(Barley_WT_weight, aes(x=Soil_type, y=Fresh_weight, fill=Soil_type)) +
geom_boxplot(aes(shape=Soil_type), width=0.3,position = dodge,outlier.color = NA, alpha=0.7)+
geom_jitter(position=position_jitterdodge(jitter.width = 0), size=3, alpha=0.3)+
# geom_jitter(position=position_jitterdodge(jitter.width = 0.3), size=3, alpha=0.3)+
