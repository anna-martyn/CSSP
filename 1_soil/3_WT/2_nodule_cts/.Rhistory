LABELS=generate_label_df(pairwise , "Soil_type")
## output Tukey results and label results
write.csv(LABELS, file =  "Anna_Nod_TukeyHSD_PINK.csv")
options(warn=-1)
# cleanup
rm(list=ls())
# directory
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
# files
nod.file <- paste("Anna_SYM_nodule.txt", sep = "")
# load data
nod <- read.table(nod.file, header=T, sep="\t")
nod <- as.data.frame(nod)
# set color for the soil_type
# colors <- data.frame(group=c("NPK", "PK","UF"),
#                      color=c("#1b9e77","#d95f02","#666666")) ### color used here is from "Paired"
colors <- data.frame(group=c("NPK", "PK","UF"),
color=c("#6D3B00","#A06A37","#D2B48C"))
# set order for plants
nod$Soil_type <- factor(nod$Soil_type, levels = colors$group)
# load plotting functions
library("ggplot2")
library("scales")
library("grid")
library(RColorBrewer)
main_theme <- theme(panel.background=element_blank(),
panel.grid.major = element_line(color = "gray90"),
panel.border = element_rect(colour = "black", fill=NA, linewidth=1),
axis.line.x=element_line(color="black"),
axis.line.y=element_line(color="black"),
axis.ticks=element_line(color="black"),
axis.text.x = element_text(size = 20),
axis.text.y = element_text(size = 20),
#legend.position="top",
legend.background=element_blank(),
legend.key=element_blank(),
text=element_text(family="sans"))
## boxplot
dodge <- position_dodge(width = 0.9)
p1 <- ggplot(nod, aes(x=Soil_type, y=pink, fill=Soil_type)) +
#geom_violin(trim=FALSE,position = dodge,scale = "width",alpha=0.3,color=NA) +
geom_boxplot(width=0.3, position = dodge, outlier.color = NA, alpha=0.7)+
geom_jitter(aes(), position=position_jitterdodge(jitter.width = 0.3), size=3, alpha=0.3)+
scale_fill_manual(values=as.character(colors$color)) +
main_theme +
ylab("Pink nodule counts/plant")+
scale_y_continuous()+
theme(legend.position="none",
plot.title = element_text(size = 20, face="bold"),
legend.title = element_text(size = 20),
strip.text.x = element_text(size = 20),
legend.text = element_text(size = 20),
axis.title.x = element_blank(),
axis.title.y = element_text(size = 20),
axis.text.y = element_text(size = 20, colour = "black"),
axis.text.x = element_text(size = 20, colour = "black"),
legend.key.size = unit(1,"cm"))
p1
ggsave(paste("LotusWT_pink_nod.png", sep=""), p1, width=3, height=6)
ggsave(paste("LotusWT_pink_nod.pdf", sep=""), p1, width=3, height=6)
p2 <- ggplot(nod, aes(x=Soil_type, y=total, fill=Soil_type)) +
#geom_violin(trim=FALSE,position = dodge,scale = "width",alpha=0.3,color=NA) +
geom_boxplot( width=0.3,position = dodge,outlier.color = NA, alpha=0.7)+
geom_jitter(aes(), position=position_jitterdodge(jitter.width = 0.3), size=3, alpha=0.3)+
scale_fill_manual(values=as.character(colors$color)) +
main_theme +
ylab("Total nodule numbers/plant")+
theme(legend.position="none",
plot.title = element_text(size = 20, face="bold"),
legend.title = element_text(size = 20),
strip.text.x = element_text(size = 20),
legend.text = element_text(size = 20),
axis.title.x = element_blank(),
axis.title.y = element_text(size = 20),
axis.text.y = element_text(size = 20, colour = "black"),
axis.text.x = element_text(size = 20, colour = "black"),
legend.key.size = unit(1,"cm"))
p2
ggsave(paste("LotusWT_total_nod.png", sep=""), p2, width=3, height=6)
ggsave(paste("LotusWT_total_nod.pdf", sep=""), p2, width=3, height=6)
# statistical analysis
library(car)
ano <- aov(pink ~ Soil_type, data=nod)
anova(ano) ### shows significant difference
### Multiple pairwise-comparsions use pair-wise t test
pairwise <- TukeyHSD(ano)
### Generate lables for significance
library(multcompView)
generate_label_df <- function(pairwise, variable){
# Extract labels and factor levels from Tukey post-hoc
Tukey.levels <- pairwise[[variable]][,4]
Tukey.labels <- data.frame(multcompLetters(Tukey.levels)['Letters'])
#I need to put the labels in the same order as in the plot :
###Tukey.labels$Type=rownames(Tukey.labels)
###Tukey.labels=Tukey.labels[order(Tukey.labels$Type) , ]
return(Tukey.labels)
}
#delete rows that comtain NA values in data
pairwise[["Soil_type"]] <- na.omit(pairwise[["Soil_type"]])
# Generate the significant labels for each of my sample
## This label can be used for adding labels on plots
LABELS=generate_label_df(pairwise , "Soil_type")
## output Tukey results and label results
write.csv(LABELS, file =  "Anna_Nod_TukeyHSD_PINK.csv")
