# Display plot
p
# Make genotype labels with italics for mutants
weight$Genotype_label <- as.character(weight$Genotype)
weight$Genotype_label[weight$Genotype_label %in% c("symrk","ccamk","nsp1","nsp2")] <-
paste0("italic('", weight$Genotype_label[weight$Genotype_label %in% c("symrk","ccamk","nsp1","nsp2")], "')")
weight$Genotype_label[weight$Genotype_label == "WT"] <- "'WT'"
# Apply same labels to summary/letters
weight_summary$Genotype_label <- weight_summary$Genotype
weight_summary$Genotype_label[weight_summary$Genotype_label %in% c("symrk","ccamk","nsp1","nsp2")] <-
paste0("italic('", weight_summary$Genotype_label[weight_summary$Genotype_label %in% c("symrk","ccamk","nsp1","nsp2")], "')")
weight_summary$Genotype_label[weight_summary$Genotype_label == "WT"] <- "'WT'"
# Plot
p <- ggplot(weight, aes(x=Genotype_label, y=Fresh_weight, fill=Genotype)) +
geom_boxplot(width=0.3, outlier.color=NA, alpha=0.7) +
geom_jitter(position=position_jitter(width=0), size=3, alpha=0.3) +
# Letters above boxes
geom_text(data=weight_summary, aes(x=Genotype_label, y=y_pos * 1.2, label=label),
inherit.aes=FALSE, size=6, parse=TRUE) +
# Overall ANOVA significance per species
geom_text(data=anova_pvals, aes(x=2, y=y_position, label=asterisk),
inherit.aes=FALSE, size=10) +
# Dummy points for upper limits
geom_blank(data=upper_limits, aes(y=Fresh_weight), inherit.aes = FALSE) +
# Colors
scale_fill_manual(values=colors$color) +
# Facet by treatment
facet_wrap(~Treatment, scales="free_y") +
# Theme
main_theme +
ylab("Shoot fresh weight/plant (g)") +
theme(
legend.position="none",
strip.text.x = element_text(size = 20),
axis.title.x = element_blank(),
axis.title.y = element_text(size = 20),
axis.text.x = element_text(size=20, color="black", angle=0, hjust=0.5)
) +
# Y axis from 0 to 1
scale_y_continuous(limits=c(0,1), expand=c(0,0))
p
# Clean up
options(warn=-1)
rm(list=ls())
