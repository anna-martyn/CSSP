print(final_plot)
ggsave("LotusSC_DAisolates_plot_root.pdf", final_plot, width = 10, height = 8)
# Overlap ----------------------------------------------------------------------
# Check overlap of DA rhizo and root isolates -> make new plot for both that includes all isolates that are either DA in root or in rhizo.
unique_rhizo_isolates <- unique(DA_rhizo_long$Isolate)
unique_root_isolates <- unique(DA_root_long$Isolate)
# Find the overlap (common isolates between rhizo and root)
overlap_isolates <- intersect(unique_rhizo_isolates, unique_root_isolates)
# Calculate the percentage of overlap
overlap_percentage <- (length(overlap_isolates) / length(unique_rhizo_isolates)) * 100
# Print the result
cat("Number of overlapping isolates:", length(overlap_isolates), "\n")
cat("Percentage of overlapping isolates in DA_rhizo:", round(overlap_percentage, 2), "%\n")
# Create a unified list of all unique isolates across DA_rhizo and DA_root
all_unique_isolates <- taxonomy$Isolate[taxonomy$Isolate %in% c(DA_rhizo_long$Isolate, DA_root_long$Isolate)]
DA_rhizo_long$Isolate <- factor(DA_rhizo_long$Isolate, levels = all_unique_isolates)
DA_root_long$Isolate <- factor(DA_root_long$Isolate, levels = all_unique_isolates)
# Ensure both DA_rhizo and DA_root contain all isolates by filling missing ones with Value = 0
DA_rhizo_full <- expand.grid(Isolate = all_unique_isolates, Gene = c("symrk", "ccamk", "nsp1", "nsp2")) %>%
left_join(DA_rhizo_long, by = c("Isolate", "Gene")) %>%
mutate(Value = ifelse(is.na(Value), 0, Value))
DA_root_full <- expand.grid(Isolate = all_unique_isolates, Gene = c("symrk", "ccamk", "nsp1", "nsp2")) %>%
left_join(DA_root_long, by = c("Isolate", "Gene")) %>%
mutate(Value = ifelse(is.na(Value), 0, Value))
DA_rhizo_full$Isolate <- factor(DA_rhizo_full$Isolate, levels = all_unique_isolates)
DA_root_full$Isolate <- factor(DA_root_full$Isolate, levels = all_unique_isolates)
# Ensure order consistency
DA_rhizo_full$Isolate <- factor(DA_rhizo_full$Isolate, levels = all_unique_isolates)
DA_root_full$Isolate <- factor(DA_root_full$Isolate, levels = all_unique_isolates)
DA_rhizo_full$Gene <- factor(DA_rhizo_full$Gene, levels = c("nsp2", "nsp1", "ccamk", "symrk"))
DA_root_full$Gene <- factor(DA_root_full$Gene, levels = levels = c("nsp2", "nsp1", "ccamk", "symrk"))
options(warn=-1)
# cleanup
rm(list=ls())
# directories
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
# load packages
library(readr)
library(ggplot2)
library(dplyr)
library(tidyr)
library(patchwork)
library(reshape2)  # This package is needed for melt function
# files
design <- read.table("LotusCSSP_LjSC_metadata.txt", header = TRUE, sep = "\t")
otu_table <- read.table("LotusCSSP_LjSC_ASVtable.txt", sep = "\t", header = TRUE, row.names = 1, check.names = FALSE)
taxonomy <- read.table("LjSC_taxonomy.txt", sep = "\t", header = TRUE, fill = TRUE)
DA_rhizo <- read_csv("DA_SynCom_Lotus_rhizo.csv")
DA_root <- read_csv("DA_SynCom_Lotus_endo.csv")
# remover f6h1 data in DA files
DA_rhizo <- DA_rhizo[,1:5]
DA_root <- DA_root[,1:5]
# re-order data matrices
idx <- design$SampleID %in% colnames(otu_table)
design <- design[idx, ]
idx <- match(design$SampleID, colnames(otu_table))
otu_table <- otu_table[, idx]
idx <- rownames(otu_table) %in% taxonomy[,1]
otu_table <- otu_table[idx, ]
idx <- match(rownames(otu_table), taxonomy[,1])
taxonomy <- taxonomy[idx, ]
# otu_table normalization
otu_table_norm <- apply(otu_table, 2, function(x) x / sum(x))
RAtable <- as.data.frame(otu_table_norm)
RAtable2 <- cbind (rownames(RAtable),RAtable)
rownames(RAtable2) <- NULL
colnames(RAtable2)[1] <- "Isolate"
### reshape data: the aim of this step is to transfer wide data to long data(check online the difference of wide and long dataset in r)
long_df <- reshape2::melt(RAtable2, id.vars = "Isolate", variable.name = "SampleID", value.name = "RA")
#add sample info
df2 <- data.frame(SampleID = design$SampleID, Genotype=design$Genotype, Compartment = design$Compartment)
df.long2 <- full_join(long_df, df2, by="SampleID")
#filter for WT and CSSP mutants
RA_CSSP <- df.long2[df.long2$Genotype %in% c("WT", "symrk", "ccamk", "nsp1", "nsp2"),]
## Make two separate RA files for rhizosphere and root
RA_CSSP_rhizo <- RA_CSSP[RA_CSSP$Compartment == "rhizosphere",]
RA_CSSP_root <- RA_CSSP[RA_CSSP$Compartment == "root",]
# Rename columns ASVid/ASV to Isolate to keep it uniform.
taxonomy <- taxonomy %>%
rename(Isolate = ASVid)
DA_rhizo <- DA_rhizo %>%
rename(Isolate = ASV)
DA_root <- DA_root %>%
rename(Isolate = ASV)
# Ensure factors are ordered alphabetically by taxonomy
taxonomy <- taxonomy %>%
arrange(order, Isolate) %>%
mutate(Isolate = factor(Isolate, levels = unique(Isolate)))
# Merge taxonomy with RA_CSSP to get sorted isolates
RA_CSSP <- RA_CSSP %>%
mutate(Isolate = factor(Isolate, levels = unique(taxonomy$Isolate)))
# Rhizosphere ---------------------------------------------------------------------------------------------------------
# Reshape DA_rhizo to long format for ggplot
DA_rhizo_long <- DA_rhizo %>%
pivot_longer(cols = c(symrk, ccamk, nsp1, nsp2), names_to = "Gene", values_to = "Value") %>%
mutate(Isolate = factor(Isolate, levels = levels(taxonomy$Isolate)),
Gene = factor(Gene, levels = c("nsp2", "nsp1", "ccamk", "symrk")))  # Set genotype order
# Define color mapping for values
value_colors <- c("-1" = "darkblue", "0" = "white", "1" = "#ba0319")
# Define colours for taxonomic orders.
colors <- data.frame(
group = c("Actinomycetales","Burkholderiales", "Caulobacterales", "Chloroflexales", "Flavobacteriales",
"Frankiales", "Gaiellales", "Gemmatimonadales", "Micrococcales",
"Micromonosporales", "Propionibacteriales", "Pseudomonadales",
"Pseudonocardiales", "Rhizobiales", "Sphingomonadales", "Streptomycetales",
"Unknown", "Xanthomonadales", "Other"),
colors = c("#5E3A6D","#645394", "#AA4488", "#CC99BB", "#ffeeef", "#114477", "#4477AA", "#77AADD",
"#44AAAA", "#77CCCC", "#117744", "#88CCAA", "#CDEBC5", "lightyellow",
"#fdbb6b", "#ffd7b5", "darkgrey", "#ffc0cb", "lightgrey")
)
taxonomy <- taxonomy %>%
left_join(colors, by = c("order" = "group"))
# Filter taxonomy to include only isolates present in DA_rhizo_long and preserve order
taxonomy_filtered <- taxonomy %>%
filter(Isolate %in% DA_rhizo_long$Isolate) %>%
mutate(Isolate = factor(Isolate, levels = taxonomy$Isolate[taxonomy$Isolate %in% DA_rhizo_long$Isolate]))  # Preserve taxonomy order
# Filter RA_means to include only Isolates present in DA_rhizo_long and preserve order
RA_means <- RA_CSSP_rhizo %>%
filter(Genotype == "WT") %>%
group_by(Isolate) %>%
summarise(mean_RA = mean(RA, na.rm = TRUE)) %>%
filter(Isolate %in% DA_rhizo_long$Isolate) %>%
mutate(Isolate = factor(Isolate, levels = taxonomy$Isolate[taxonomy$Isolate %in% DA_rhizo_long$Isolate]))  # Ensure same order
# Create the heatmap
heatmap_plot <- ggplot(DA_rhizo_long, aes(x = Isolate, y = Gene, fill = factor(Value))) +
geom_tile() +
scale_fill_manual(values = value_colors) +
theme_minimal() +
theme(
axis.text.x = element_text(angle = 90, vjust = 0.5, hjust = 1, color = "black"),
axis.text.y = element_text(color = "black"),  # Set y-axis tick color to black
axis.ticks = element_line(color = "black"),  # Set axis ticks to black
panel.border = element_rect(color = "black", fill = NA, size = 1),  # Add black border
text = element_text(color = "black")  # Set all fonts to black
) +
labs(fill = "Gene Value", x = "Isolate", y = "Genotype") +
scale_x_discrete(limits = levels(taxonomy_filtered$Isolate))  # Filtered and ordered Isolate levels for heatmap
# Create the bar plot
bar_plot <- ggplot(RA_means, aes(x = Isolate, y = mean_RA)) +
geom_bar(stat = "identity", fill = "grey") +
theme_minimal() +
theme(
axis.text.x = element_blank(),  # Set x-axis tick color to black
axis.text.y = element_text(color = "black"),  # Set y-axis tick color to black
axis.ticks = element_line(color = "black"),  # Set axis ticks to black
legend.position = "none",
panel.border = element_rect(color = "black", fill = NA, size = 1),  # Add black border
text = element_text(color = "black")  # Set all fonts to black
) +
labs(y = "Mean RA in WT", x = "") +
scale_x_discrete(limits = levels(taxonomy_filtered$Isolate))  # Filtered and ordered Isolate levels for bar plot
# Create the taxonomy plot
tax_plot <- ggplot(taxonomy_filtered, aes(x = Isolate, y = 1, fill = order)) +
geom_tile() +
scale_fill_manual(values = setNames(colors$colors, colors$group)) +  # Map taxonomy orders to specific colors
theme_void() +
theme(
legend.position = "right",  # Position the legend on the right
axis.text = element_blank(),
axis.ticks = element_blank(),
) +
labs(fill = "Bacterial order") +
scale_x_discrete(limits = levels(taxonomy_filtered$Isolate))  # Filtered and ordered Isolate levels for taxonomy plot
# Combine the plots
final_plot <- (bar_plot / tax_plot / heatmap_plot) + plot_layout(heights = c(1, 0.2, 4))
print(final_plot)
ggsave("LotusSC_DAisolates_plot_rhizo.pdf", final_plot, width = 10, height = 8)
